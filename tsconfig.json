{
	"compilerOptions": {
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"lib": ["DOM", "ES5", "ES6", "ES7"],
		"allowSyntheticDefaultImports": true,
		"strictNullChecks": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts"]
}
